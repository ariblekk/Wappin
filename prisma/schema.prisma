// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- Application Models ---

model Device {
  id        String   @id @default(cuid())
  name      String
  status    String   @default("disconnected") // connected, connecting, disconnected
  qr        String?  @db.Text
  phone     String?
  waName    String?
  waImage   String?  @db.Text
  
  userId    String
  
  autoReplies AutoReply[]
  broadcasts  Broadcast[]
  messages    Message[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions    WaSession[]

  @@index([userId])
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  phone     String
  tags      String?  @default("")
  
  userId    String
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model WaSession {
  id        String   @id @default(cuid())
  deviceId  String
  device    Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  dataType  String   // 'creds' or 'keys'
  dataId    String   // e.g. 'pre-key-1'
  content   String   @db.Text // JSON serialized content
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([deviceId, dataType, dataId])
  @@index([deviceId])
}

model AutoReply {
  id        String   @id @default(cuid())
  keyword   String
  response  String   @db.Text
  type      String   @default("exact") // exact, contains
  
  deviceId  String
  device    Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  
  userId    String
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([deviceId])
}

model Broadcast {
  id        String   @id @default(cuid())
  name      String
  message   String   @db.Text
  recipients Json     // Store as JSON: [{phone: string, status: string}]
  status    String   @default("pending") // pending, processing, completed
  total     Int      @default(0)
  sent      Int      @default(0)
  failed    Int      @default(0)
  timestamp Int      // Scheduled timestamp (Unix seconds)
  
  deviceId  String
  device    Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  
  userId    String
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([deviceId])
}

model Message {
  id        String   @id @default(cuid())
  deviceId  String
  device    Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  
  to        String
  text      String   @db.Text
  status    String   @default("sent") // sent, received, failed
  sentAt    DateTime @default(now())
  
  createdAt DateTime @default(now())

  @@index([deviceId])
}

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user_code String   @unique @default(cuid())
  plan      String   @default("Free")
  apiKey    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([apiKey])
  @@index([user_code])
}
